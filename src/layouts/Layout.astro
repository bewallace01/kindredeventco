---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  /** Nav key to mark as current: home | about | services | portfolio | testimonials | contact */
  active?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  active = '',
  noindex = false,
} = Astro.props;

const navItems = [
  { key: 'home', href: '/', label: 'Home' },
  { key: 'about', href: '/about', label: 'About' },
  { key: 'services', href: '/services', label: 'Services' },
  { key: 'portfolio', href: '/portfolio', label: 'Weddings' },
  { key: 'testimonials', href: '/testimonials', label: 'Love Notes' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {noindex && <meta name="robots" content="noindex" />}
  <meta name="theme-color" content="#8B7DA3" />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  {ogTitle && <meta property="og:title" content={ogTitle} />}
  {ogDescription && <meta property="og:description" content={ogDescription} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400&family=Pinyon+Script&family=Jost:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="container">
      <nav class="nav" aria-label="Primary">
        <a class="nav__brand" href="/">Kindred <span>Event Collective</span></a>
        <button class="nav__toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu"><span></span><span></span><span></span></button>
        <ul class="nav__menu" id="nav-menu">
          {navItems.map((item) => (
            <li>
              <a
                class="nav__link"
                href={item.href}
                aria-current={active === item.key ? 'page' : undefined}
              >{item.label}</a>
            </li>
          ))}
          <li>
            <a
              class="btn btn--primary"
              href="/contact"
              aria-current={active === 'contact' ? 'page' : undefined}
            >Inquire</a>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="container">
      <div class="footer__grid">
        <div>
          <p class="footer__brand">Kindred Event Collective<span class="script">timeless celebrations</span></p>
          <p style="margin-top:1rem;max-width:36ch;">Boutique wedding planning &amp; design based in Charlotte, North Carolina — serving couples across the Carolinas and beyond.</p>
        </div>
        <div>
          <h4>Explore</h4>
          <nav class="footer__links" aria-label="Footer">
            <a href="/about">About</a>
            <a href="/services">Services</a>
            <a href="/portfolio">Weddings</a>
            <a href="/testimonials">Love Notes</a>
            <a href="/contact">Inquire</a>
          </nav>
        </div>
        <div>
          <h4>Connect</h4>
          <div class="footer__links">
            <a href="mailto:hello@kindredeventcollective.com">hello@kindredeventcollective.com</a>
            <a href="tel:+17045550100">(704) 555-0100</a>
            <a href="#" rel="noopener">Instagram</a>
            <a href="#" rel="noopener">Pinterest</a>
          </div>
        </div>
      </div>
      <div class="footer__bottom">
        <span>&copy; <span data-year>2026</span> Kindred Event Collective. All rights reserved.</span>
        <span>Charlotte, North Carolina</span>
      </div>
    </div>
  </footer>

  <script src="/js/main.js" defer></script>
</body>
</html>
