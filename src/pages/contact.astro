---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Inquire | Contact Kindred Event Collective, Charlotte Wedding Planner"
  description="Begin planning your Charlotte or Carolinas wedding with Kindred Event Collective. Share your date and vision, and we'll be in touch within two business days."
  canonical="https://www.kindredeventcollective.com/contact.html"
  ogTitle="Inquire | Kindred Event Collective"
  ogDescription="Tell us about your wedding. Boutique planning in Charlotte and the Carolinas."
  active="contact"
>
  <main id="main">

    <section class="page-hero" style="min-height:48vh;" aria-label="Contact">
      <div class="page-hero__media"></div>
      <div class="page-hero__scrim"></div>
      <div class="container container--narrow">
        <span class="script" style="color:var(--peach);font-size:var(--step-3);">let’s begin</span>
        <h1>Inquire</h1>
        <p class="lead">Tell us about the two of you and the celebration you’re dreaming of. We respond to every inquiry within two business days.</p>
      </div>
    </section>

    <section class="section" aria-labelledby="form-h">
      <div class="container">
        <div class="split" style="align-items:start;">

          <!-- FORM -->
          <div class="reveal">
            <h2 id="form-h">Send us a note</h2>
            <p class="form__note" style="margin-bottom:var(--space-md);">Fields marked * are required.</p>

            <div class="form-success" data-form-success role="status">
              <strong>Thank you!</strong> Your inquiry is on its way. We’ll be in touch within two business days.
            </div>

            <div class="form-error" data-form-error role="alert">
              <strong>Hmm, that didn’t send.</strong> Please try again, or email us directly at <a href="mailto:hello@kindredeventcollective.com">hello@kindredeventcollective.com</a>.
            </div>

            <!-- Formspree: replace YOUR_FORM_ID below with the ID from your Formspree form (https://formspree.io). -->
            <form class="form" data-contact-form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" novalidate>
              <!-- Honeypot: bots fill this hidden field; Formspree silently drops those submissions. -->
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;" />
              <input type="hidden" name="_subject" value="New wedding inquiry — Kindred Event Collective" />
              <div class="form__row form__row--2">
                <div class="field">
                  <label for="firstName">First name *</label>
                  <input type="text" id="firstName" name="firstName" autocomplete="given-name" required />
                </div>
                <div class="field">
                  <label for="partnerName">Partner’s name</label>
                  <input type="text" id="partnerName" name="partnerName" autocomplete="off" />
                </div>
              </div>

              <div class="form__row form__row--2">
                <div class="field">
                  <label for="email">Email *</label>
                  <input type="email" id="email" name="email" autocomplete="email" required />
                </div>
                <div class="field">
                  <label for="phone">Phone</label>
                  <input type="tel" id="phone" name="phone" autocomplete="tel" />
                </div>
              </div>

              <div class="form__row form__row--2">
                <div class="field">
                  <label for="date">Wedding date (or season)</label>
                  <input type="text" id="date" name="date" placeholder="e.g. Fall 2027" />
                </div>
                <div class="field">
                  <label for="service">Service of interest</label>
                  <select id="service" name="service">
                    <option value="">Select one…</option>
                    <option>Full-Service Planning &amp; Design</option>
                    <option>Partial Planning</option>
                    <option>Wedding Management</option>
                    <option>Not sure yet</option>
                  </select>
                </div>
              </div>

              <div class="field">
                <label for="venue">Venue or location</label>
                <input type="text" id="venue" name="venue" placeholder="Charlotte, Lake Norman, Asheville…" />
              </div>

              <div class="field">
                <label for="message">Tell us about your day *</label>
                <textarea id="message" name="message" required placeholder="Your vision, guest count, what matters most to you…"></textarea>
              </div>

              <div>
                <button type="submit" class="btn btn--primary">Send Inquiry</button>
              </div>
            </form>
          </div>

          <!-- DETAILS -->
          <aside class="reveal reveal-delay-1" aria-label="Contact details">
            <div class="ph ph--wide ph--g3" data-label="Studio / detail image" style="margin-bottom:var(--space-md);"></div>
            <span class="eyebrow">Reach Us Directly</span>
            <h3 style="margin-bottom:var(--space-sm);">We’d love to hear from you</h3>
            <p class="footer__links" style="display:grid;gap:0.6rem;color:var(--text-soft);">
              <a class="link-underline" href="mailto:hello@kindredeventcollective.com" style="text-transform:none;letter-spacing:0;font-family:var(--font-body);">hello@kindredeventcollective.com</a>
              <a class="link-underline" href="tel:+17045550100" style="text-transform:none;letter-spacing:0;font-family:var(--font-body);">(704) 555-0100</a>
            </p>
            <div class="divider"></div>
            <p><strong>Based in</strong><br>Charlotte, North Carolina</p>
            <p class="mt-md"><strong>Serving</strong><br>Charlotte, Lake Norman, Asheville, the Triad &amp; beyond — and available for travel.</p>
            <p class="mt-md"><strong>Studio hours</strong><br>Mon–Fri, 9am–5pm ET</p>
            <div class="divider"></div>
            <p class="footer__links" style="display:flex;gap:var(--space-md);">
              <a class="link-underline" href="#" rel="noopener">Instagram</a>
              <a class="link-underline" href="#" rel="noopener">Pinterest</a>
            </p>
          </aside>

        </div>
      </div>
    </section>

  </main>
</Layout>
