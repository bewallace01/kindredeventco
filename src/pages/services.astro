---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Services &amp; Investment | Kindred Event Collective Wedding Planning"
  description="Full-service planning, partial planning, and wedding management for couples in Charlotte and the Carolinas. Explore Kindred Event Collective' boutique packages and process."
  canonical="https://www.kindredeventcollective.com/services"
  ogTitle="Services &amp; Investment | Kindred Event Collective"
  ogDescription="Boutique wedding planning packages — full-service, partial, and day-of management — in Charlotte, NC."
  active="services"
>
  <main id="main">

    <section class="page-hero" aria-label="Services">
      <div class="page-hero__media"></div>
      <div class="page-hero__scrim"></div>
      <div class="container container--narrow">
        <span class="script" style="color:var(--peach);font-size:var(--step-3);">how we help</span>
        <h1>Services &amp; investment</h1>
        <p class="lead">Three thoughtfully structured ways to plan — each built around the same promise of calm, personal, detail-rich support.</p>
      </div>
    </section>

    <!-- SERVICE PACKAGES -->
    <section class="section" aria-labelledby="packages-h">
      <div class="container container--narrow">
        <div class="section-head reveal">
          <span class="eyebrow">Packages</span>
          <h2 id="packages-h">Find your level of support</h2>
        </div>

        <div class="service reveal">
          <div><span class="script" style="font-size:var(--step-2);">i.</span></div>
          <div>
            <h3>Full-Service Planning &amp; Design</h3>
            <p>Our signature, start-to-finish partnership. From the first vision conversation to the final send-off, we handle design direction, vendor curation, budget management, timelines, and on-the-day execution. The most complete — and most relaxing — way to plan.</p>
          </div>
          <div class="service__price">From&nbsp;$8,500</div>
        </div>

        <div class="service reveal">
          <div><span class="script" style="font-size:var(--step-2);">ii.</span></div>
          <div>
            <h3>Partial Planning</h3>
            <p>For couples who’ve begun but want a professional to bring it together. We join you a few months out to refine your design, recommend and book remaining vendors, build your timeline, and manage the final stretch — then run the day itself.</p>
          </div>
          <div class="service__price">From&nbsp;$5,000</div>
        </div>

        <div class="service reveal">
          <div><span class="script" style="font-size:var(--step-2);">iii.</span></div>
          <div>
            <h3>Wedding Management</h3>
            <p>Often called “day-of,” though it begins weeks earlier. You plan; we perfect. We review your details, confirm every vendor, craft a minute-by-minute timeline, and orchestrate the entire celebration so you and your family can simply be present.</p>
          </div>
          <div class="service__price">From&nbsp;$2,800</div>
        </div>

        <p class="form__note mt-lg reveal">Every wedding is unique. Final investment is tailored to your guest count, venues, and scope — shared in a custom proposal after we connect. <em>Placeholder pricing — update before launch.</em></p>
      </div>
    </section>

    <!-- WHAT'S INCLUDED -->
    <section class="section section--alt" aria-labelledby="incl-h">
      <div class="container">
        <div class="section-head text-center mx-auto reveal">
          <span class="eyebrow">Always Included</span>
          <h2 id="incl-h">The Kindred standard</h2>
          <p class="lead mx-auto" style="max-width:58ch;">No matter which package you choose, every couple receives:</p>
        </div>
        <div class="grid grid--3">
          <article class="card reveal"><h3>Unlimited guidance</h3><p>Email and scheduled calls throughout your engagement — questions never go unanswered.</p></article>
          <article class="card reveal reveal-delay-1"><h3>Trusted vendor access</h3><p>Introductions to the Carolinas’ best photographers, florists, caterers, and more.</p></article>
          <article class="card reveal reveal-delay-2"><h3>Custom timeline</h3><p>A detailed, vendor-shared day-of schedule so everyone moves in sync.</p></article>
          <article class="card reveal"><h3>Budget stewardship</h3><p>Clear tracking and honest counsel to keep your investment where it matters most.</p></article>
          <article class="card reveal reveal-delay-1"><h3>On-site direction</h3><p>A calm, capable lead and assistant managing your day from setup to send-off.</p></article>
          <article class="card reveal reveal-delay-2"><h3>Rehearsal coordination</h3><p>We run your rehearsal so the wedding party walks in confident.</p></article>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="section" aria-labelledby="process-h">
      <div class="container">
        <div class="section-head text-center mx-auto reveal">
          <span class="eyebrow">The Experience</span>
          <h2 id="process-h">Our planning journey</h2>
        </div>
        <div class="grid grid--4">
          <div class="step reveal"><span class="step__num">1</span><h3>Discover</h3><p>A relaxed consultation to understand your vision, priorities, and the feeling you want to create.</p></div>
          <div class="step reveal reveal-delay-1"><span class="step__num">2</span><h3>Design</h3><p>A bespoke creative direction and curated vendor team aligned to your style and budget.</p></div>
          <div class="step reveal reveal-delay-2"><span class="step__num">3</span><h3>Coordinate</h3><p>We manage logistics, contracts, and timelines, checking in at every milestone.</p></div>
          <div class="step reveal reveal-delay-3"><span class="step__num">4</span><h3>Celebrate</h3><p>We run the day seamlessly while you soak in every moment.</p></div>
        </div>
      </div>
    </section>

    <section class="cta-band" aria-labelledby="cta-h">
      <div class="cta-band__media"></div>
      <div class="cta-band__scrim"></div>
      <div class="container container--narrow">
        <span class="eyebrow" style="color:var(--peach);">Limited Dates</span>
        <h2 id="cta-h">Ready to begin?</h2>
        <p>Request a custom proposal and let’s design a celebration that’s unmistakably yours.</p>
        <a class="btn btn--light" href="/contact">Request a Proposal</a>
      </div>
    </section>

  </main>
</Layout>
