---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WeddingPlanner',
  name: 'Kindred Event Collective',
  description: 'Boutique luxury wedding planning studio in Charlotte, North Carolina.',
  areaServed: 'Charlotte, North Carolina and the Carolinas',
  url: 'https://www.kindredeventcollective.com/',
  image: 'https://www.kindredeventcollective.com/assets/brand/brand-board.jpeg',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Charlotte',
    addressRegion: 'NC',
    addressCountry: 'US',
  },
  priceRange: '$$$',
};
---
<Layout
  title="Kindred Event Collective | Luxury Wedding Planning in Charlotte, NC"
  description="Kindred Event Collective is a boutique wedding planning studio in Charlotte, North Carolina, crafting timeless, stress-free celebrations for couples across the Carolinas."
  canonical="https://www.kindredeventcollective.com/"
  ogTitle="Kindred Event Collective | Luxury Wedding Planning in Charlotte, NC"
  ogDescription="Boutique, full-service wedding planning for couples seeking timeless elegance in Charlotte and across the Carolinas."
  ogImage="https://www.kindredeventcollective.com/assets/brand/brand-board.jpeg"
  active="home"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline slot="head" />

  <main id="main">

    <!-- ============================ HERO ============================ -->
    <section class="hero" aria-label="Introduction">
      <div class="hero__media" role="img" aria-label="Soft, romantic Carolina sunset over a wedding celebration"></div>
      <div class="hero__scrim"></div>
      <div class="container">
        <div class="hero__inner">
          <span class="script">rooted in the Carolinas</span>
          <h1>Timeless celebrations, thoughtfully designed.</h1>
          <p class="hero__sub">Boutique wedding planning and design for couples who want a celebration that feels effortless, personal, and unmistakably theirs — in Charlotte and across the Carolinas.</p>
          <div class="hero__cta">
            <a class="btn btn--light" href="/contact">Begin Your Story</a>
            <a class="btn btn--ghost" href="/portfolio">View Our Weddings</a>
          </div>
        </div>
      </div>
      <span class="scroll-hint" aria-hidden="true">Scroll</span>
    </section>

    <!-- ===================== INTRO / BRAND STORY ===================== -->
    <section class="section" aria-labelledby="intro-h">
      <div class="container">
        <div class="split">
          <div class="reveal">
            <span class="eyebrow">Welcome</span>
            <h2 id="intro-h">A calm, capable hand from “yes” to “I do.”</h2>
            <p class="lead">Planning a wedding should feel as joyful as the day itself. At Kindred Event Collective, we take on the logistics, the timelines, and the thousand tiny details — so you can stay present for the moments that matter.</p>
            <p>Led by founder <strong>Nezzie</strong>, our Charlotte-based studio pairs refined design with steady, behind-the-scenes coordination. The result is a celebration that looks editorial, runs seamlessly, and feels deeply like you.</p>
            <a class="link-underline mt-md" href="/about" style="display:inline-block;">Meet Nezzie &rarr;</a>
          </div>
          <div class="reveal reveal-delay-1">
            <div class="ph ph--tall ph--arch" data-label="Portrait — planner at work"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FEATURED SERVICES ====================== -->
    <section class="section section--alt" aria-labelledby="services-h">
      <div class="container">
        <div class="section-head text-center mx-auto reveal">
          <span class="eyebrow">What We Offer</span>
          <h2 id="services-h">Three ways to be cared for</h2>
          <p class="lead mx-auto" style="max-width:60ch;">Every couple arrives somewhere different on their planning journey. Choose the level of support that meets you there.</p>
        </div>
        <div class="grid grid--3">
          <article class="card reveal">
            <span class="card__num">i.</span>
            <h3>Full-Service Planning &amp; Design</h3>
            <p>Start-to-finish partnership across design, vendors, budget, and logistics. The most hands-on, most relaxing way to plan.</p>
            <a class="link-underline mt-md" href="/services" style="display:inline-block;">Explore &rarr;</a>
          </article>
          <article class="card reveal reveal-delay-1">
            <span class="card__num">ii.</span>
            <h3>Partial Planning</h3>
            <p>You’ve made a start; we bring structure, polish, and trusted vendor connections to carry it home beautifully.</p>
            <a class="link-underline mt-md" href="/services" style="display:inline-block;">Explore &rarr;</a>
          </article>
          <article class="card reveal reveal-delay-2">
            <span class="card__num">iii.</span>
            <h3>Wedding Management</h3>
            <p>For the couple who has it handled. We step in before the day to refine, confirm, and run everything flawlessly.</p>
            <a class="link-underline mt-md" href="/services" style="display:inline-block;">Explore &rarr;</a>
          </article>
        </div>
      </div>
    </section>

    <!-- ===================== PORTFOLIO HIGHLIGHTS ==================== -->
    <section class="section" aria-labelledby="portfolio-h">
      <div class="container">
        <div class="section-head text-center mx-auto reveal">
          <span class="eyebrow">Selected Celebrations</span>
          <h2 id="portfolio-h">A glimpse of recent weddings</h2>
        </div>
        <div class="gallery">
          <a class="tile tile--lg reveal" href="/portfolio">
            <div class="ph ph--pano" data-label="Featured wedding — wide"></div>
            <div class="tile__caption"><span class="script">Hannah &amp; Reid</span><br><span>The Duke Mansion · Charlotte</span></div>
          </a>
          <a class="tile reveal reveal-delay-1" href="/portfolio">
            <div class="ph ph--tall ph--g2" data-label="Wedding portrait"></div>
            <div class="tile__caption"><span class="script">Olivia &amp; James</span><br><span>Lake Norman</span></div>
          </a>
          <a class="tile reveal reveal-delay-1" href="/portfolio">
            <div class="ph ph--tall ph--g3" data-label="Tablescape detail"></div>
            <div class="tile__caption"><span class="script">Sofia &amp; Will</span><br><span>Foxhall Resort</span></div>
          </a>
          <a class="tile reveal reveal-delay-2" href="/portfolio">
            <div class="ph ph--tall ph--g4" data-label="Ceremony moment"></div>
            <div class="tile__caption"><span class="script">Grace &amp; Daniel</span><br><span>Asheville</span></div>
          </a>
        </div>
        <div class="text-center mt-lg reveal">
          <a class="btn btn--ghost" href="/portfolio">View the Full Portfolio</a>
        </div>
      </div>
    </section>

    <!-- ===================== TRUST / STATS ========================== -->
    <section class="section--tight section--alt" aria-label="By the numbers">
      <div class="container">
        <div class="stats">
          <div class="reveal"><div class="stat__num">150+</div><div class="stat__label">Weddings Planned</div></div>
          <div class="reveal reveal-delay-1"><div class="stat__num">10 yrs</div><div class="stat__label">In the Carolinas</div></div>
          <div class="reveal reveal-delay-2"><div class="stat__num">5.0★</div><div class="stat__label">Average Couple Rating</div></div>
        </div>
      </div>
    </section>

    <!-- ===================== TESTIMONIAL FEATURE ==================== -->
    <section class="section" aria-labelledby="quote-h">
      <div class="container">
        <h2 id="quote-h" class="visually-hidden">What couples say</h2>
        <figure class="quote reveal">
          <span class="quote__mark" aria-hidden="true">&ldquo;</span>
          <blockquote>Nezzie made the entire year feel calm. On the day itself, we didn’t lift a finger — we just got to be married. It was the most beautiful, seamless day of our lives.</blockquote>
          <cite>Hannah &amp; Reid · The Duke Mansion</cite>
        </figure>
        <div class="text-center mt-lg reveal">
          <a class="link-underline" href="/testimonials">Read More Love Notes &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ===================== PROCESS ================================ -->
    <section class="section section--alt" aria-labelledby="process-h">
      <div class="container">
        <div class="section-head text-center mx-auto reveal">
          <span class="eyebrow">The Experience</span>
          <h2 id="process-h">How we plan, together</h2>
          <p class="lead mx-auto" style="max-width:58ch;">A clear, unhurried path — so you always know what’s next.</p>
        </div>
        <div class="grid grid--4">
          <div class="step reveal">
            <span class="step__num">1</span>
            <h3>Discover</h3>
            <p>We begin with a conversation about your vision, your guests, and the feeling you want your day to hold.</p>
          </div>
          <div class="step reveal reveal-delay-1">
            <span class="step__num">2</span>
            <h3>Design</h3>
            <p>A cohesive creative direction — palette, mood, and details — tailored entirely to the two of you.</p>
          </div>
          <div class="step reveal reveal-delay-2">
            <span class="step__num">3</span>
            <h3>Coordinate</h3>
            <p>We curate vendors, manage budget and timeline, and keep every moving piece on track.</p>
          </div>
          <div class="step reveal reveal-delay-3">
            <span class="step__num">4</span>
            <h3>Celebrate</h3>
            <p>On the day, we run everything quietly in the background while you’re fully present.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FINAL CTA ============================== -->
    <section class="cta-band" aria-labelledby="cta-h">
      <div class="cta-band__media"></div>
      <div class="cta-band__scrim"></div>
      <div class="container container--narrow">
        <span class="eyebrow" style="color:var(--peach);">Now Booking</span>
        <h2 id="cta-h">Let’s create something unforgettable.</h2>
        <p>We take on a limited number of weddings each year so every couple receives our full attention. Tell us about your day — we’d love to hear it.</p>
        <a class="btn btn--light" href="/contact">Start the Conversation</a>
      </div>
    </section>

  </main>
</Layout>
